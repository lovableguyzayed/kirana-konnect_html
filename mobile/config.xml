<?xml version='1.0' encoding='utf-8'?>
<widget id="com.kiranakonnect.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>Kirana Konnect</name>
    <description>
        Kirana Konnect - store management for kirana shops. Native Android shell
        that loads the hosted web app.
    </description>
    <author email="lovableguyzayed@gmail.com" href="https://github.com/lovableguyzayed/kirana-konnect_html">
        Kirana Konnect
    </author>

    <!-- Local splash/loader shell. It redirects to the hosted app (see www/js/config.js). -->
    <content src="index.html" />

    <!-- Allow the WebView to navigate to the hosted backend. Update the domain
         below if you deploy somewhere other than *.onrender.com. -->
    <allow-navigation href="https://*.onrender.com/*" />

    <!-- Allow the OS to handle these outside the app. -->
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />

    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    <!-- NOTE: do not use the legacy "BackgroundColor" preference with a 0x-style
         value here - cordova-android copies it verbatim into an Android <color>
         resource, which requires #RRGGBB format, and the invalid value breaks
         resource compilation ("Invalid <color> for given resource value"). -->
    <preference name="BackgroundColor" value="#4CAF50" />
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="loglevel" value="DEBUG" />

    <platform name="android">
        <preference name="AndroidWindowSplashScreenBackgroundColor" value="#4CAF50" />
        <!-- Camera permission for the in-app barcode scanner (getUserMedia). -->
        <config-file target="AndroidManifest.xml" parent="/manifest">
            <uses-permission android:name="android.permission.CAMERA" />
        </config-file>

        <icon density="ldpi" src="res/android/icon-36-ldpi.png" />
        <icon density="mdpi" src="res/android/icon-48-mdpi.png" />
        <icon density="hdpi" src="res/android/icon-72-hdpi.png" />
        <icon density="xhdpi" src="res/android/icon-96-xhdpi.png" />
        <icon density="xxhdpi" src="res/android/icon-144-xxhdpi.png" />
        <icon density="xxxhdpi" src="res/android/icon-192-xxxhdpi.png" />
    </platform>

    <engine name="android" spec="^14.0.0" />
</widget>
